# URL de conexão com o banco de dados (Pooler do Supabase para a aplicação rodar)
# Exemplo: postgresql://postgres.oqknnpxbfqpxyjgemojm:[SENHA]@aws-0-[regiao].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[REF_PROJETO]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL de conexão direta para Migrações do Prisma
# Exemplo: postgresql://postgres:[SENHA]@db.oqknnpxbfqpxyjgemojm.supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:[SENHA]@db.[REF_PROJETO].supabase.co:5432/postgres"

# Chave de API do Google AI Studio (Gemini / Gemma 4)
GEMINI_API_KEY="sua_chave_de_api_do_google_ai_studio"

# Configurações do Supabase (para Storage e chamadas de API)
SUPABASE_URL="https://seu_projeto.supabase.co"
SUPABASE_SECRET_KEY="sua_chave_secreta_sb_secret_xxx"
SUPABASE_PUBLISHABLE_KEY="sua_chave_publica_sb_publishable_xxx"

# Segredo para assinatura de tokens JWT locais no NestJS
JWT_SECRET="seu_segredo_jwt_super_seguro_e_longo"

# Configurações do Scraper de Vagas
SCRAPER_PATH="C:\projetos\aimatcher\scraper"
SCRAPER_API_TOKEN="um_token_de_sistema_super_seguro_e_longo"
SCRAPER_DEFAULT_QUERIES="Python,React,Node,TypeScript"
SCRAPER_VACANCY_TTL_DAYS=21

# Configurações de Concorrência e Rate Limiting de IA
BATCH_CONCURRENCY_LIMIT=3
GEMINI_MIN_REQUEST_INTERVAL_MS=2000
