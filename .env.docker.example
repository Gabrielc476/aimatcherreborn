# ------------------------------------------------------------------------------
# CONFIGURAÇÕES DO DOCKER COMPOSE - AI MATCHER (SIMULAÇÃO LOCAL)
# ------------------------------------------------------------------------------
# Copie este arquivo para ".env.docker" na mesma pasta antes de rodar os containers.
# Exemplo: cp .env.docker.example .env.docker
# ------------------------------------------------------------------------------

# 1. VARIÁVEIS DE AMBIENTE DO BACKEND (NESTJS)
# Simula os limites físicos do Render Starter (512MB RAM, 0.5 CPU)
PORT=10000
FRONTEND_URL=http://localhost:3000

# URLs de Banco de Dados (Use o Connection Pooler IPv4 na porta 6543 caso sua rede local não tenha IPv6)
DATABASE_URL="postgresql://postgres.[REF_PROJETO]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF_PROJETO]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Credenciais de Integração Supabase (Storage e APIs)
SUPABASE_URL="https://seu_projeto.supabase.co"
SUPABASE_SECRET_KEY="sua_chave_secreta_sb_secret_xxx"
SUPABASE_PUBLISHABLE_KEY="sua_chave_publica_sb_publishable_xxx"

# Chave do Google AI Studio (Para execução do Gemma 4 / Gemini)
GEMINI_API_KEY="sua_chave_de_api_do_google_ai_studio"

# JWT Secret para autenticação de sessões locais do NestJS
JWT_SECRET="seu_segredo_jwt_super_seguro_e_longo_para_simulacao"

# 2. VARIÁVEIS DE AMBIENTE DO FRONTEND (NEXTJS)
# Simula a Vercel Hobby
NEXT_PUBLIC_API_URL=http://localhost:10000

# 3. CONFIGURAÇÕES DO SCRAPER (WORKER EFÊMERO)
# Simula o GitHub Actions enviando vagas diretamente via API interna do Docker
BACKEND_URL=http://backend:10000
SCRAPER_API_TOKEN="um_token_de_sistema_super_seguro_e_longo"
SCRAPER_DEFAULT_QUERIES="Python,React,Node,TypeScript"
HEADLESS=true
